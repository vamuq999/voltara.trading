# =========================================
# OPENAI
# =========================================

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# =========================================
# WALLETCONNECT
# =========================================

NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=xxxxxxxxxxxxxxxx

# =========================================
# RPC ENDPOINTS
# =========================================

NEXT_PUBLIC_ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

NEXT_PUBLIC_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# =========================================
# MARKET DATA
# =========================================

NEXT_PUBLIC_COINGECKO_API=https://api.coingecko.com/api/v3

NEXT_PUBLIC_BINANCE_API=https://api.binance.com/api/v3

# =========================================
# TRADECORE ENGINE
# =========================================

NEXT_PUBLIC_TRADECORE_MODE=simulation

NEXT_PUBLIC_ENABLE_REAL_TRADING=false

NEXT_PUBLIC_ENABLE_AI_ANALYSIS=true

NEXT_PUBLIC_ENABLE_AUTONOMOUS_AGENTS=true

# =========================================
# SECURITY
# =========================================

NEXT_PUBLIC_ALLOWED_CHAIN=ethereum

NEXT_PUBLIC_ENABLE_WITHDRAWALS=false

NEXT_PUBLIC_ENABLE_APPROVALS=false

# =========================================
# APP
# =========================================

NEXT_PUBLIC_APP_NAME=Voltara Trading

NEXT_PUBLIC_APP_URL=https://voltaratrading.vercel.app